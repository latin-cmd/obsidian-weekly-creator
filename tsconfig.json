{
    "compilerOptions": {
        "baseUrl": ".",
        "inlineSourceMap": true,
        "inlineSources": true,
        "module": "ESNext",
        "target": "ES2018",
        "allowImportingTsExtensions": true,
        "moduleResolution": "bundler",
        "importHelpers": true,
        "isolatedModules": true,
        "strictNullChecks": true,
        "verbatimModuleSyntax": true,
        "lib": ["ES6", "DOM"]
    },
    "include": ["**/*.ts"]
}
