{
    "name": "obsidian-weekly-creator",
    "version": "1.0.0",
    "description": "Obsidian plugin for creating weekly files",
    "main": "main.js",
    "scripts": {
        "dev": "node esbuild.config.mjs",
        "build": "tsc --noEmit --skipLibCheck && node esbuild.config.mjs production",
        "deploy": "powershell -ExecutionPolicy Bypass -File deploy.ps1"
    },
    "devDependencies": {
        "@types/node": "^22.0.0",
        "builtin-modules": "3.3.0",
        "esbuild": "0.21.5",
        "obsidian": "latest",
        "typescript": "5.5.3"
    }
}
